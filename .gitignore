/target

# 認証情報ストア — リポジトリに含めない（パブリック）
/.mat-store/
*.kvs

# 実機トポロジ・証明書をうっかりコミットしない
*.pem
*.der
*.chip

# Docker から取り出した chip-tool バイナリ
/chip-tool

# Docker から取り出した example device バイナリ（Phase 5 開発用）
/chip-all-clusters-app

# クロスビルド成果物（実機へ scp 用）
/dist/

# デバッグ実行ログ
*.log

# E2E スクリプトのキャッシュ（PAA 証明書など、コミットしない）
/.e2e-cache/

# Python ビルド生成物
__pycache__/
